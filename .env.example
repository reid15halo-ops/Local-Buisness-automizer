# ============================================================
# FreyAI Core — Environment Configuration
# Copy to .env and fill in your values.
# ============================================================

# ----- Supabase (Required) -----
# Get these from: Supabase Dashboard > Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----- Backend -----
PORT=8000
ENVIRONMENT=development
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ----- Frontend (set via localStorage, not .env) -----
# In the browser console:
#   localStorage.setItem('freyai_supabase_url', '<SUPABASE_URL>')
#   localStorage.setItem('freyai_supabase_anon_key', '<SUPABASE_ANON_KEY>')

# ----- Stripe (Optional — for payment flows) -----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- Email / SMTP (Optional — for Edge Functions) -----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ----- AI Services (Optional) -----
GEMINI_API_KEY=

# ----- n8n Automation (Optional) -----
N8N_WEBHOOK_URL=https://n8n.yourdomain.com
N8N_API_KEY=
