# FreyAI Visions Email Relay - Configuration
# Copy to .env and fill in values

# API Authentication (REQUIRED - relay will not start without this)
API_SECRET=your-secret-here

# SMTP (Postfix/Dovecot on VPS - self-hosted)
# For localhost relay (Postfix on same server):
SMTP_HOST=127.0.0.1
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=angebote@freyaivisions.de
SMTP_PASS=your-mail-account-password

# For remote SMTP with STARTTLS:
# SMTP_HOST=mail.freyaivisions.de
# SMTP_PORT=587
# SMTP_SECURE=false

# Sender identity
SENDER_NAME=FreyAI Visions
SENDER_EMAIL=angebote@freyaivisions.de

# Listen address (default: 127.0.0.1 - only accessible from localhost/nginx)
# LISTEN_HOST=127.0.0.1
