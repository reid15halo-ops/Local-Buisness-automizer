{
  "name": "Zahlungsabgleich (Bank Payment Auto-Matching v3)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 7 * * *"
            }
          ]
        },
        "timezone": "Europe/Berlin"
      },
      "id": "node-schedule-trigger",
      "name": "Daily 07:00 Berlin",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300],
      "notes": "Runs every day at 07:00 Europe/Berlin (1 hour before dunning check). CRON: 0 7 * * *"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://bankaccountdata.gocardless.com/api/v2/token/new/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Accept",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "secret_id",
              "value": "={{ $env[\"GOCARDLESS_SECRET_ID\"] }}"
            },
            {
              "name": "secret_key",
              "value": "={{ $env[\"GOCARDLESS_SECRET_KEY\"] }}"
            }
          ]
        },
        "options": {
          "timeout": 15000
        }
      },
      "id": "node-auth-token",
      "name": "GoCardless: Get Access Token",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300],
      "notes": "Authenticates with GoCardless using secret_id + secret_key. Returns access token (24h validity) and refresh token (30 days). Env vars: GOCARDLESS_SECRET_ID, GOCARDLESS_SECRET_KEY."
    },
    {
      "parameters": {
        "method": "GET",
        "url": "=https://bankaccountdata.gocardless.com/api/v2/accounts/{{ $env[\"GOCARDLESS_ACCOUNT_ID\"] }}/transactions/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $node[\"GoCardless: Get Access Token\"].json[\"access\"] }}"
            },
            {
              "name": "Accept",
              "value": "application/json"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "date_from",
              "value": "={{ new Date(Date.now() - 2 * 24 * 60 * 60 * 1000).toISOString().split('T')[0] }}"
            },
            {
              "name": "date_to",
              "value": "={{ new Date().toISOString().split('T')[0] }}"
            }
          ]
        },
        "options": {
          "timeout": 20000
        }
      },
      "id": "node-fetch-transactions",
      "name": "Fetch Last 2 Days Transactions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300],
      "notes": "GoCardless Open Banking API. Fetches last 2 days of transactions (daily overlap for delayed bookings). Uses fresh access token from previous step."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-transactions",
              "leftValue": "={{ $json[\"transactions\"] && $json[\"transactions\"][\"booked\"] && $json[\"transactions\"][\"booked\"].length }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-check-transactions",
      "name": "Has Transactions?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 300]
    },
    {
      "parameters": {
        "fieldToSplitOut": "transactions.booked",
        "options": {
          "destinationFieldName": ""
        }
      },
      "id": "node-split-transactions",
      "name": "Split Booked Transactions",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [1120, 200],
      "notes": "Splits the transactions.booked array into individual items for per-transaction processing"
    },
    {
      "parameters": {
        "mode": "expression",
        "assignments": {
          "assignments": [
            {
              "id": "txn-amount",
              "name": "txn_amount",
              "value": "={{ parseFloat($json[\"transactionAmount\"][\"amount\"]) }}",
              "type": "number"
            },
            {
              "id": "txn-currency",
              "name": "txn_currency",
              "value": "={{ $json[\"transactionAmount\"][\"currency\"] }}",
              "type": "string"
            },
            {
              "id": "txn-id",
              "name": "txn_id",
              "value": "={{ $json[\"transactionId\"] || $json[\"internalTransactionId\"] }}",
              "type": "string"
            },
            {
              "id": "txn-date",
              "name": "txn_booking_date",
              "value": "={{ $json[\"bookingDate\"] || $json[\"valueDate\"] }}",
              "type": "string"
            },
            {
              "id": "txn-value-date",
              "name": "txn_value_date",
              "value": "={{ $json[\"valueDate\"] || $json[\"bookingDate\"] }}",
              "type": "string"
            },
            {
              "id": "txn-creditor",
              "name": "txn_creditor_name",
              "value": "={{ $json[\"creditorName\"] || $json[\"debtorName\"] || '' }}",
              "type": "string"
            },
            {
              "id": "txn-reference",
              "name": "txn_reference",
              "value": "={{ $json[\"remittanceInformationUnstructured\"] || $json[\"remittanceInformationStructured\"] || '' }}",
              "type": "string"
            },
            {
              "id": "txn-iban",
              "name": "txn_creditor_iban",
              "value": "={{ $json[\"creditorAccount\"] ? $json[\"creditorAccount\"][\"iban\"] : ($json[\"debtorAccount\"] ? $json[\"debtorAccount\"][\"iban\"] : '') }}",
              "type": "string"
            },
            {
              "id": "txn-end-to-end",
              "name": "txn_end_to_end_id",
              "value": "={{ $json[\"endToEndId\"] || '' }}",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": false,
        "options": {}
      },
      "id": "node-normalize-transaction",
      "name": "Normalize Transaction Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1340, 200],
      "notes": "Flattens GoCardless transaction object into normalized fields. Added value_date and end_to_end_id for improved matching."
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "gocardless_transactions",
        "returnAll": false,
        "limit": 1,
        "filterType": "string",
        "filterString": "=external_id=eq.{{ $json[\"txn_id\"] }}&gc_account_id=eq.{{ $env[\"GOCARDLESS_ACCOUNT_ID\"] }}"
      },
      "id": "node-dedup-check",
      "name": "Dedup: Check Existing",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1560, 200],
      "credentials": {
        "supabaseApi": {
          "id": "cred-supabase-api",
          "name": "Supabase API"
        }
      },
      "notes": "Check if this transaction was already imported (prevents duplicates on overlapping date ranges)"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "is-new",
              "leftValue": "={{ !$json[\"id\"] }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-is-new",
      "name": "Is New Transaction?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1780, 200],
      "notes": "Skip already-imported transactions. Only process genuinely new ones."
    },
    {
      "parameters": {
        "operation": "create",
        "tableId": "gocardless_transactions",
        "dataToSend": "defineBelow",
        "fieldsToSend": {
          "fieldValues": [
            {
              "fieldId": "tenant_id",
              "fieldValue": "={{ $env[\"TENANT_ID\"] }}"
            },
            {
