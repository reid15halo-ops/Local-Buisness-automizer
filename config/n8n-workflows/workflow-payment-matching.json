            },
            {
              "fieldId": "booking_date",
              "fieldValue": "={{ $node[\"Normalize Transaction Fields\"].json[\"txn_booking_date\"] }}"
            },
            {
              "fieldId": "value_date",
              "fieldValue": "={{ $node[\"Normalize Transaction Fields\"].json[\"txn_value_date\"] }}"
            },
            {
              "fieldId": "amount",
