            }
          ]
        }
      },
      "id": "node-log-matched",
      "name": "INSERT automation_log (matched)",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [3540, 60],
      "credentials": {
        "supabaseApi": {
          "id": "cred-supabase-api",
          "name": "Supabase API"
        }
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://api.telegram.org/bot{{ $env[\"TELEGRAM_BOT_TOKEN\"] }}/sendMessage",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "chat_id",
              "value": "={{ $env[\"TELEGRAM_CHAT_ID\"] }}"
            },
            {
              "name": "text",
              "value": "=Zahlungseingang: {{ $json[\"txn_amount\"] }} EUR von {{ $json[\"txn_creditor_name\"] }}. Rechnung {{ $json[\"rechnung_nummer\"] }} als bezahlt markiert ({{ $json[\"method\"] }}, {{ Math.round($json[\"confidence\"] * 100) }}% Konfidenz)."
            },
            {
              "name": "parse_mode",
              "value": "HTML"
            }
          ]
        },
        "options": {
          "timeout": 10000
        }
      },
