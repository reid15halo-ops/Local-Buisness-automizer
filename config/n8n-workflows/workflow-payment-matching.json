            },
            {
              "fieldId": "matched_at",
              "fieldValue": "={{ new Date().toISOString() }}"
            }
          ]
        }
      },
      "id": "node-update-gc-match",
      "name": "UPDATE gocardless_transactions (match)",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [3100, 180],
      "credentials": {
        "supabaseApi": {
          "id": "cred-supabase-api",
          "name": "Supabase API"
        }
      },
      "notes": "Store match result back on the gocardless_transactions row for audit trail."
    },
    {
      "parameters": {
        "operation": "create",
