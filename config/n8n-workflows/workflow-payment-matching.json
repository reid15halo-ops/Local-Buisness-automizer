            }
          ]
        }
      },
      "id": "node-store-transaction",
      "name": "INSERT gocardless_transactions",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2000, 100],
      "credentials": {
        "supabaseApi": {
          "id": "cred-supabase-api",
          "name": "Supabase API"
        }
      },
      "notes": "Persist raw transaction to gocardless_transactions table for audit trail and dedup."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "positive-amount",
              "leftValue": "={{ $node[\"Normalize Transaction Fields\"].json[\"txn_amount\"] }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-credit-only",
      "name": "Credit Transactions Only",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2220, 100],
      "notes": "Only process incoming payments (positive amounts) for invoice matching. Outgoing payments are stored but not matched."
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "rechnungen",
        "returnAll": false,
        "limit": 3,
        "filterType": "string",
        "filterString": "=or=(status.eq.offen,status.eq.versendet)&nummer=ilike.*{{ $node[\"Normalize Transaction Fields\"].json[\"txn_reference\"].replace(/[^a-zA-Z0-9-]/g, '') }}*"
      },
      "id": "node-lookup-by-reference",
      "name": "Tier 1: Match by Verwendungszweck (95%)",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2440, 40],
      "credentials": {
        "supabaseApi": {
          "id": "cred-supabase-api",
          "name": "Supabase API"
        }
      },
      "notes": "Tier 1 (95% confidence): Match invoice number (nummer) in transaction Verwendungszweck. Searches rechnungen with status offen or versendet."
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "rechnungen",
        "returnAll": false,
        "limit": 3,
        "filterType": "string",
        "filterString": "=or=(status.eq.offen,status.eq.versendet)&brutto=gte.{{ $node[\"Normalize Transaction Fields\"].json[\"txn_amount\"] - 0.01 }}&brutto=lte.{{ $node[\"Normalize Transaction Fields\"].json[\"txn_amount\"] + 0.01 }}"
      },
      "id": "node-lookup-by-amount-exact",
      "name": "Tier 2: Match by Amount + Name (85%)",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2440, 160],
      "credentials": {
        "supabaseApi": {
          "id": "cred-supabase-api",
          "name": "Supabase API"
        }
      },
      "notes": "Tier 2 (85% confidence): Exact brutto amount match (+-0.01 EUR). Customer name cross-checked in code node downstream."
    },
    {
      "parameters": {
        "operation": "getAll",
        "tableId": "rechnungen",
        "returnAll": false,
        "limit": 5,
        "filterType": "string",
        "filterString": "=or=(status.eq.offen,status.eq.versendet)&brutto=gte.{{ $node[\"Normalize Transaction Fields\"].json[\"txn_amount\"] * 0.99 }}&brutto=lte.{{ $node[\"Normalize Transaction Fields\"].json[\"txn_amount\"] * 1.01 }}"
      },
      "id": "node-lookup-by-amount-fuzzy",
      "name": "Tier 3: Match by Amount +/-1% (70%)",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [2440, 280],
      "credentials": {
        "supabaseApi": {
          "id": "cred-supabase-api",
          "name": "Supabase API"
        }
      },
      "notes": "Tier 3 (70% confidence): Fuzzy amount match within 1% tolerance for fee/rounding differences."
    },
    {
      "parameters": {
        "jsCode": "// 3-tier matching logic: pick best match from all tiers\nconst tier1 = $input.all().filter(i => i.json._tier === 1);\nconst tier2 = $input.all().filter(i => i.json._tier === 2);\nconst tier3 = $input.all().filter(i => i.json._tier === 3);\nconst txn = $node[\"Normalize Transaction Fields\"].json;\n\nlet match = null;\nlet confidence = 0;\nlet method = 'none';\n\n// Tier 1: Reference match (95%)\nif (tier1.length > 0 && tier1[0].json.id) {\n  match = tier1[0].json;\n  confidence = 0.95;\n  method = 'reference_match';\n}\n\n// Tier 2: Amount + name match (85%)\nif (!match && tier2.length > 0) {\n  const txName = (txn.txn_creditor_name || '').toLowerCase();\n  for (const candidate of tier2) {\n    const kundeName = (candidate.json.kunde_name || '').toLowerCase();\n    const firstWord = kundeName.split(' ')[0];\n    if (firstWord.length >= 3 && txName.includes(firstWord)) {\n      match = candidate.json;\n      confidence = 0.85;\n      method = 'amount_and_name';\n      break;\n    }\n  }\n}\n\n// Tier 3: Fuzzy amount (70%)\nif (!match && tier3.length > 0 && tier3[0].json.id) {\n  match = tier3[0].json;\n  confidence = 0.70;\n  method = 'amount_fuzzy';\n}\n\nreturn [{\n  json: {\n    matched: !!match,\n    rechnung_id: match ? match.id : null,\n    rechnung_nummer: match ? match.nummer : null,\n    kunde_name: match ? match.kunde_name : null,\n    brutto: match ? match.brutto : null,\n    confidence,\n    method,\n    txn_id: txn.txn_id,\n    txn_amount: txn.txn_amount,\n    txn_booking_date: txn.txn_booking_date,\n    txn_creditor_name: txn.txn_creditor_name,\n    txn_reference: txn.txn_reference,\n    txn_creditor_iban: txn.txn_creditor_iban,\n    gc_transaction_db_id: $node[\"INSERT gocardless_transactions\"].json.id || null\n  }\n}];"
      },
      "id": "node-pick-best-match",
      "name": "Pick Best Match (3-tier)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2660, 160],
      "notes": "Evaluates all 3 tiers and picks the highest-confidence match. Returns match details + confidence score."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "match-found",
              "leftValue": "={{ $json[\"matched\"] }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-match-found",
      "name": "Match Found?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [2880, 160]
    },
    {
