            },
            {
              "fieldId": "currency",
              "fieldValue": "={{ $node[\"Normalize Transaction Fields\"].json[\"txn_currency\"] }}"
            },
            {
              "fieldId": "counterparty_name",
              "fieldValue": "={{ $node[\"Normalize Transaction Fields\"].json[\"txn_creditor_name\"] }}"
            },
            {
              "fieldId": "counterparty_iban",
              "fieldValue": "={{ $node[\"Normalize Transaction Fields\"].json[\"txn_creditor_iban\"] }}"
            },
            {
              "fieldId": "reference",
              "fieldValue": "={{ $node[\"Normalize Transaction Fields\"].json[\"txn_reference\"] }}"
            },
            {
              "fieldId": "end_to_end_id",
              "fieldValue": "={{ $node[\"Normalize Transaction Fields\"].json[\"txn_end_to_end_id\"] }}"
