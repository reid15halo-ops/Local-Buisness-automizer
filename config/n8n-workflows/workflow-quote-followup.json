a;font-size:13px;margin:0;\">Mit freundlichen Gr&uuml;&szlig;en<br><strong style=\"color:#a1a1aa;\">{{ $env[\"COMPANY_NAME\"] || 'FreyAI Visions' }}</strong></p><p style=\"color:#52525b;font-size:11px;margin:24px 0 0;padding-top:16px;border-top:1px solid #27272a;\">Sie erhalten diese E-Mail, weil wir Ihnen ein Angebot erstellt haben. <a href=\"{{ $env[\"PORTAL_URL\"] || 'https://portal.freyai.de' }}/abmelden?ref={{ $json[\"id\"] }}\" style=\"color:#6366f1;text-decoration:underline;\">Keine weiteren Erinnerungen erhalten</a></p></td></tr></table></td></tr></table></body></html>",
              "type": "string"
            },
            {
              "id": "stage-r3",
              "name": "followup_action",
              "value": "quote_followup_reminder_3",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "id": "node-template-r3",
      "name": "Template: Reminder 3 (Day 14)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [2160, 500],
      "notes": "Day 14 — Final reminder: mentions exact days until expiry, validity date, offers updated quote if needs changed."
    },
    {
      "parameters": {
        "mode": "expression",
        "assignments": {
          "assignments": [
            {
              "id": "subject-expired",
              "name": "email_subject",
              "value": "D\u00fcrfen wir Ihnen ein aktualisiertes Angebot erstellen?",
              "type": "string"
            },
            {
