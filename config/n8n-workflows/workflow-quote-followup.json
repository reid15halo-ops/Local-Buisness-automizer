{
  "name": "Angebots-Nachverfolgung (Quote Follow-Up Pipeline)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 9 * * *"
            }
          ]
        },
        "timezone": "Europe/Berlin"
      },
      "id": "node-schedule-trigger",
      "name": "Daily 09:00 Berlin",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300],
      "notes": "Runs every day at 09:00 Europe/Berlin. CRON: 0 9 * * *"
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env[\"SUPABASE_URL\"] }}/rest/v1/angebote",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env[\"SUPABASE_SERVICE_ROLE_KEY\"] }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env[\"SUPABASE_SERVICE_ROLE_KEY\"] }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "select",
              "value": "id,kunde_name,kunde_email,netto,brutto,leistungsart,created_at,gueltig_bis"
            },
            {
              "name": "status",
              "value": "eq.offen"
            },
            {
              "name": "gueltig_bis",
              "value": "=gte.{{ new Date().toISOString().split('T')[0] }}"
            }
          ]
        },
        "options": {
          "timeout": 15000
        }
      },
      "id": "node-fetch-open-quotes",
      "name": "GET Open Angebote",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 300],
      "continueOnFail": true,
      "notes": "Fetches all open quotes (status=offen) where gueltig_bis >= today from Supabase angebote table. Selects: id, kunde_name, kunde_email, netto, brutto, leistungsart, created_at, gueltig_bis."
    },
    {
      "parameters": {
        "jsCode": "const now = Date.now();\nconst results = [];\n\nfor (const item of $input.all()) {\n  const data = item.json;\n  const createdAt = new Date(data.created_at).getTime();\n  const gueltigBis = new Date(data.gueltig_bis).getTime();\n\n  const daysSinceCreated = Math.floor((now - createdAt) / 86400000);\n  const daysUntilExpiry = Math.floor((gueltigBis - now) / 86400000);\n\n  let followUpStage = 'skip';\n\n  if (daysSinceCreated >= 28) {\n    followUpStage = 'expired';\n  } else if (daysSinceCreated >= 14) {\n    followUpStage = 'reminder_3';\n  } else if (daysSinceCreated >= 7) {\n    followUpStage = 'reminder_2';\n  } else if (daysSinceCreated >= 3) {\n    followUpStage = 'reminder_1';\n  }\n\n  results.push({\n    json: {\n      ...data,\n      daysSinceCreated,\n      daysUntilExpiry,\n      followUpStage\n    }\n  });\n}\n\nreturn results;"
      },
      "id": "node-calc-days",
      "name": "Calculate Days & Follow-Up Stage",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [720, 300],
      "notes": "For each quote: calculates daysSinceCreated and daysUntilExpiry. Assigns followUpStage: 3d=reminder_1, 7d=reminder_2, 14d=reminder_3, 28d+=expired, otherwise=skip."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "filter-actionable",
              "leftValue": "={{ $json[\"followUpStage\"] }}",
              "rightValue": "skip",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-filter-actionable",
      "name": "Only Actionable Quotes",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [960, 300],
      "notes": "Filters out quotes where followUpStage='skip' (no action needed). Only passes quotes that are due for a follow-up email."
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $env[\"SUPABASE_URL\"] }}/rest/v1/email_log",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{ $env[\"SUPABASE_SERVICE_ROLE_KEY\"] }}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env[\"SUPABASE_SERVICE_ROLE_KEY\"] }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "reference_id",
              "value": "=eq.{{ $json[\"id\"] }}"
            },
            {
              "name": "action",
              "value": "like.quote_followup_%"
            },
            {
              "name": "created_at",
              "value": "=gte.{{ new Date(Date.now() - 2 * 86400000).toISOString() }}"
            },
            {
              "name": "select",
              "value": "id"
            }
          ]
        },
        "options": {
          "timeout": 10000
        }
      },
      "id": "node-check-duplicate",
      "name": "Check Duplicate Follow-Up",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1200, 300],
      "continueOnFail": true,
      "notes": "Checks email_log for existing follow-up emails sent in the last 2 days for this quote. Prevents sending duplicate follow-ups."
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  // The HTTP response is an array. If empty, no duplicate exists.\n  const responseData = item.json;\n  const isArray = Array.isArray(responseData);\n  const hasDuplicate = isArray ? responseData.length > 0 : false;\n\n  if (!hasDuplicate) {\n    // Pass through the original quote data from the previous node\n    // The quote data is carried forward in the item\n    results.push(item);\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: { _empty: true } }];"
      },
      "id": "node-filter-duplicates",
      "name": "Filter Already Sent",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1440, 300],
      "notes": "Filters out quotes that already received a follow-up in the last 2 days. Passes through only quotes needing a new follow-up."
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "not-empty",
              "leftValue": "={{ $json[\"_empty\"] }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-skip-empty",
      "name": "Skip Empty Results",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1660, 300],
      "notes": "Guards against empty result set from duplicate filter. Only continues if there are actual quotes to process."
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json[\"followUpStage\"] }}",
                    "rightValue": "reminder_1",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "reminder_1"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json[\"followUpStage\"] }}",
                    "rightValue": "reminder_2",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "reminder_2"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json[\"followUpStage\"] }}",
                    "rightValue": "reminder_3",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "reminder_3"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json[\"followUpStage\"] }}",
                    "rightValue": "expired",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "expired"
            }
          ]
        },
        "options": {}
      },
      "id": "node-stage-switch",
      "name": "Switch by Follow-Up Stage",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [1900, 300],
      "notes": "Routes quotes to different email templates based on followUpStage. Output 0: reminder_1 (Day 3), Output 1: reminder_2 (Day 7), Output 2: reminder_3 (Day 14), Output 3: expired (Day 28+)."
    },
    {
      "parameters": {
        "mode": "expression",
        "assignments": {
          "assignments": [
            {
              "id": "subject-r1",
              "name": "email_subject",
              "value": "Haben Sie noch Fragen zu unserem Angebot?",
              "type": "string"
            },
            {
              "id": "body-r1",
              "name": "email_body",
              "value": "=<!DOCTYPE html><html><head><meta charset=\"utf-8\"></head><body style=\"margin:0;padding:0;background-color:#09090b;font-family:'Helvetica Neue',Arial,sans-serif;\"><table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#09090b;padding:40px 0;\"><tr><td align=\"center\"><table width=\"600\" cellpadding=\"0\" cellspacing=\"0\" style=\"background-color:#18181b;border-radius:16px;overflow:hidden;\"><tr><td style=\"background-color:#6366f1;padding:24px 32px;\"><h1 style=\"color:#fafafa;margin:0;font-size:22px;font-weight:700;\">{{ $env[\"COMPANY_NAME\"] || 'FreyAI Visions' }}</h1></td></tr><tr><td style=\"padding:32px;\"><h2 style=\"color:#fafafa;margin:0 0 16px;font-size:20px;\">Guten Tag {{ $json[\"kunde_name\"] }},</h2><p style=\"color:#a1a1aa;font-size:15px;line-height:1.6;margin:0 0 16px;\">vielen Dank f&uuml;r Ihr Interesse an unseren Leistungen. Wir haben Ihnen vor kurzem ein Angebot f&uuml;r <strong style=\"color:#fafafa;\">{{ $json[\"leistungsart\"] }}</strong> zugesendet und m&ouml;chten uns erkundigen, ob Sie noch Fragen dazu haben.</p><p style=\"color:#a1a1aa;font-size:15px;line-height:1.6;margin:0 0 24px;\">Unser Angebotsbetrag: <strong style=\"color:#fafafa;\">{{ $json[\"brutto\"] }} EUR (brutto)</strong></p><p style=\"color:#a1a1aa;font-size:15px;line-height:1.6;margin:0 0 24px;\">Gerne stehen wir Ihnen f&uuml;r R&uuml;ckfragen zur Verf&uuml;gung. Sie k&ouml;nnen Ihr Angebot auch jederzeit in unserem Kundenportal einsehen.</p><table cellpadding=\"0\" cellspacing=\"0\" style=\"margin:0 0 24px;\"><tr><td style=\"background-color:#6366f1;border-radius:8px;padding:12px 24px;\"><a href=\"{{ $env[\"PORTAL_URL\"] || 'https://portal.freyai.de' }}\" style=\"color:#fafafa;text-decoration:none;font-weight:600;font-size:15px;\">Angebot im Portal ansehen</a></td></tr></table><p style=\"color:#71717a;font-size:13px;margin:0;\">Mit freundlichen Gr&uuml;&szlig;en<br><strong style=\"color:#a1a1aa;\">{{ $env[\"COMPANY_NAME\"] || 'FreyAI Visions' }}</strong></p><p style=\"color:#52525b;font-size:11px;margin:24px 0 0;padding-top:16px;border-top:1px solid #27272a;\">Sie erhalten diese E-Mail, weil wir Ihnen ein Angebot erstellt haben. <a href=\"{{ $env[\"PORTAL_URL\"] || 'https://portal.freyai.de' }}/abmelden?ref={{ $json[\"id\"] }}\" style=\"color:#6366f1;text-decoration:underline;\">Keine weiteren Erinnerungen erhalten</a></p></td></tr></table></td></tr></table></body></html>",
              "type": "string"
            },
            {
              "id": "stage-r1",
              "name": "followup_action",
              "value": "quote_followup_reminder_1",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "id": "node-template-r1",
      "name": "Template: Reminder 1 (Day 3)",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [2160, 100],
      "notes": "Day 3 — Friendly check-in: asks if they have questions, mentions portal access, references the leistungsart and brutto amount."
    },
    {
      "parameters": {
        "mode": "expression",
        "assignments": {
          "assignments": [
