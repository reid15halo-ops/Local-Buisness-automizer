# FreyAI Visions Email Relay - Configuration
# Copy to .env and fill in values

# API Authentication
API_SECRET=your-secret-here

# SMTP (Proton Mail Bridge)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=your-proton-email@protonmail.com
SMTP_PASS=bridge-generated-password

# Sender
SENDER_NAME=FreyAI Visions
SENDER_EMAIL=your-proton-email@protonmail.com
